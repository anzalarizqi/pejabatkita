# ── LLM Providers (at least one required for scraper + verifier) ──────────────
# Add whichever keys you have. Unused providers are automatically skipped.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MOONSHOT_API_KEY=
ZHIPUAI_API_KEY=

# Force a specific provider (optional): anthropic | openai | google | groq | moonshot
ACTIVE_LLM_PROVIDER=

# Optional: use your own SearXNG instance instead of the public one
SEARXNG_URL=https://searx.be

# ── Supabase (required for seed script + batch import) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
